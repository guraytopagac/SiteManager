{
  "name": "mavikent-site-yonetimi",
  "private": true,
  "version": "1.1.6",
  "description": "Mavikent Site Yönetimi Uygulaması",
  "author": "Güray Topağaç",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"vite\" \"npm run electron:dev\"",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "rebuild": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.mavikent.sitemanager",
    "productName": "Mavikent Site Yönetimi",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "database/*.js",
      "database/schema/**/*",
      "database/migrations/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "artifactName": "Mavikent-Site-Yonetimi-Setup-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "perMachine": false,
      "oneClick": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mavikent Site Yönetimi"
    },
    "publish": {
      "provider": "github",
      "owner": "guraytopagac",
      "repo": "SiteManager"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "electron-serve": "^3.0.1",
    "electron-updater": "^6.8.9",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sweetalert2": "^11.26.25"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "3.8.3",
    "react-icons": "^5.6.0",
    "vite": "^8.0.12",
    "wait-on": "^8.0.3"
  }
}
